let selectedFile = {'2':null};
function handleFile(event, slot) {
  const file = event.target.files[0]; if (!file) return;
  selectedFile[slot] = file;
  document.getElementById('fn'+slot).textContent = file.name;
  document.getElementById('fs'+slot).textContent = (file.size/1024).toFixed(1)+' KB';
  document.getElementById('fp'+slot).classList.add('show');
  document.getElementById('ab'+slot).disabled = false;
}
function removeFile(slot) {
  selectedFile[slot]=null;
  document.getElementById('fp'+slot).classList.remove('show');
  document.getElementById('ab'+slot).disabled=true;
  document.getElementById('uf'+slot).value='';
  const ar=document.getElementById('ar'+slot);
  ar.classList.remove('show'); ar.innerHTML='';
}

// ══ AI ANALYSIS ══
async function analyzeReport(slot) {
  const file = selectedFile[slot]; if (!file) return;
  const btn = document.getElementById('ab'+slot);
  const ar = document.getElementById('ar'+slot);
  btn.disabled=true;
  btn.innerHTML='<span class="spinner"></span> جاري التحليل...';
  const base64 = await fileToBase64(file);
  const prompt=`أنت طبيب متخصص في تحليل التقارير الطبية لمرضى الأمراض المزمنة (القلب، السكر، ضغط الدم).
قم بتحليل هذا التقرير وأعطِ إجابة بالعربية في JSON فقط (بلا نص خارج JSON):
{"summary":"ملخص التقرير","readings":[{"name":"اسم المقياس","value":"القيمة","unit":"الوحدة","status":"normal|high|low"}],"diagnosis":"التشخيص العام","recommendations":["توصية 1","توصية 2","توصية 3"],"urgency":"routine|followup|urgent"}`;
  try {
    const messages=[];
    if (file.type.startsWith('image/')) {
      messages.push({role:'user',content:[{type:'image',source:{type:'base64',media_type:file.type,data:base64}},{type:'text',text:prompt}]});
    } else {
      messages.push({role:'user',content:[{type:'document',source:{type:'base64',media_type:'application/pdf',data:base64}},{type:'text',text:prompt}]});
    }
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages})});
    const data=await res.json();
    const text=data.content?.map(i=>i.text||'').join('')||'';
    let result;
    try{result=JSON.parse(text.replace(/```json|```/g,'').trim());}catch{result=null;}
    renderResult(ar,result,file.name);
  } catch(e){ renderError(ar,'حدث خطأ في الاتصال. يرجى المحاولة مرة أخرى.'); }
  btn.disabled=false;
  btn.innerHTML='<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg> تحليل مرة أخرى';
}

function renderResult(container,result,filename){
  if(!result){renderError(container,'تعذّر قراءة التقرير. يرجى التأكد من وضوح الصورة.');return;}
  const urgMap={routine:{label:'روتيني',cls:'badge-ok'},followup:{label:'يحتاج متابعة',cls:'badge-warn'},urgent:{label:'عاجل',cls:'badge-danger'}};
  const urg=urgMap[result.urgency]||urgMap.routine;
  const stMap={normal:{label:'طبيعي',cls:'val-normal'},high:{label:'مرتفع',cls:'val-high'},low:{label:'منخفض',cls:'val-low'}};
  const rdHTML=result.readings?.map(r=>{const s=stMap[r.status]||stMap.normal;return`<div class="ai-row"><span class="ai-key">${r.name}</span><span class="ai-val ${s.cls}">${r.value} ${r.unit||''} — ${s.label}</span></div>`;}).join('')||'';
  const rcHTML=result.recommendations?.map(r=>`<div class="ai-row"><span>• ${r}</span></div>`).join('')||'';
  container.innerHTML=`
    <div class="ai-header">
      <div class="ai-avatar"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2v-4M9 21H5a2 2 0 0 1-2-2v-4m0 0h18"/></svg></div>
      <div><div class="ai-name">تحليل الذكاء الاصطناعي</div><div class="ai-sub">${filename} — <span class="status-pill ${urg.cls}" style="font-size:.7rem;padding:2px 8px;">${urg.label}</span></div></div>
    </div>
    <div class="ai-body">
      <div class="ai-section"><div class="ai-section-title">📝 ملخص التقرير</div><div style="font-size:.86rem;line-height:1.8;color:#444;">${result.summary||'—'}</div></div>
      ${rdHTML?`<div class="ai-section"><div class="ai-section-title">📊 نتائج القياسات</div>${rdHTML}</div>`:''}
      <div class="ai-section"><div class="ai-section-title">🏥 التشخيص العام</div><div style="font-size:.86rem;line-height:1.8;color:#444;">${result.diagnosis||'—'}</div></div>
      ${rcHTML?`<div class="ai-section"><div class="ai-section-title">💡 التوصيات</div>${rcHTML}</div>`:''}
    </div>`;
  container.classList.add('show');
}
function renderError(container,msg){container.innerHTML=`<div style="text-align:center;padding:2rem;color:#b71c1c;font-size:.88rem;"><div style="font-size:2rem;margin-bottom:.5rem;">⚠️</div><div>${msg}</div></div>`;container.classList.add('show');}
function fileToBase64(file){return new Promise((res,rej)=>{const r=new FileReader();r.onload=()=>res(r.result.split(',')[1]);r.onerror=()=>rej(new Error('فشل قراءة الملف'));r.readAsDataURL(file);});}

// drag/drop
const uz2=document.getElementById('uz2');
if(uz2){
  uz2.addEventListener('dragover',e=>{e.preventDefault();uz2.classList.add('drag');});
  uz2.addEventListener('dragleave',()=>uz2.classList.remove('drag'));
  uz2.addEventListener('drop',e=>{e.preventDefault();uz2.classList.remove('drag');const f=e.dataTransfer.files[0];if(f)handleFile({target:{files:[f]}},'2');});
}

// ══ INIT ══
buildDoctorsGrid();
</script>
