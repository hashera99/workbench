    <div class="bar anim d1"></div>
    <div class="stats anim d2">
      <div class="stat"><span class="stat-ic">🫀</span><span class="stat-n">٢٤١</span><span class="stat-l">مريض قلب</span></div>
      <div class="stat"><span class="stat-ic">🩸</span><span class="stat-n">١٨٦</span><span class="stat-l">مريض سكري</span></div>
      <div class="stat"><span class="stat-ic">📊</span><span class="stat-n">١٥٣</span><span class="stat-l">ضغط الدم</span></div>
