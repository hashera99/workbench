<!-- ════════════════════════════════════
     PAGE 5 — SUPERVISOR
════════════════════════════════════ -->
<div class="page" id="supervisorPage">
  <div class="topbar">
    <div class="topbar-left">
      <button class="back-btn" onclick="goBack()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>رجوع
      </button>
      <div class="topbar-logo">
        <svg width="26" height="26" viewBox="0 0 100 100" fill="none"><path d="M64 22C52 24.5 40 35 40 50C40 65 52 75.5 66 75.5C58 80 49 81 40 78.5C24 73.5 14 61 14 50C14 35 25 22.5 40 18.5C48 16 56.5 17.5 64 22Z" fill="#C8102E"/><circle cx="72" cy="34" r="6" fill="#C8102E" opacity="0.7"/></svg>
        <span>الرعاية الصحية</span>
      </div>
      <span class="plan-tag">مشرف المركز</span>
    </div>
    <div class="topbar-right">
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="topbar-avatar" id="supAvatar">م</div>
        <span class="topbar-name" id="supName">المستخدم</span>
      </div>
      <button class="logout-btn" onclick="logout()">تسجيل الخروج</button>
    </div>
  </div>
  <div class="sup-body">
    <div class="dash-title anim">لوحة مشرف المركز</div>
    <div class="dash-sub anim d1">نظرة شاملة على أداء المراكز الصحية والمرضى</div>
    <div class="metric-grid anim d1">
      <div class="metric"><span class="metric-icon">🏥</span><span class="metric-val">٦</span><span class="metric-lbl">مراكز صحية نشطة</span><span class="metric-badge badge-ok">جميعها مفتوحة</span></div>
      <div class="metric"><span class="metric-icon">👥</span><span class="metric-val">٥٨٠</span><span class="metric-lbl">إجمالي المرضى</span><span class="metric-badge badge-ok">طبيعي</span></div>
      <div class="metric"><span class="metric-icon">🚨</span><span class="metric-val">٧</span><span class="metric-lbl">حالات حرجة اليوم</span><span class="metric-badge badge-danger">تتطلب متابعة</span></div>
      <div class="metric"><span class="metric-icon">📋</span><span class="metric-val">٤٣</span><span class="metric-lbl">تقارير مرفوعة اليوم</span><span class="metric-badge badge-ok">محدّثة</span></div>
