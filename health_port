        دخول إلى النظام
      </button>
      <div class="or-div anim d4" style="margin:1.2rem 0 0.9rem;"><div class="or-line"></div><span class="or-t">أو الدخول حسب التخصص</span><div class="or-line"></div></div>
      <!-- ONLY 2 role buttons now -->
      <div class="role-grid anim d4" style="grid-template-columns:1fr 1fr;">
        <button class="role-btn" onclick="goToPage('doctorsPage','loginPage')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>طبيب أخصائي
        </button>
        <button class="role-btn" onclick="goToPage('supervisorPage','loginPage')">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>مشرف مركز
        </button>
      </div>
      <p class="fn anim d4">للدعم الفني <a onclick="goToPage('supportPage','loginPage')">فريق تقنية المعلومات</a> &nbsp;|&nbsp; v2.6.0</p>
    </div>
  </div>
</div>

<!-- ════════════════════════════════════
     PAGE 2 — PLAN SELECTION
════════════════════════════════════ -->
<div class="page" id="planPage">
  <div style="padding:1.5rem 2rem 0;width:100%;">
    <button class="back-btn" onclick="goBack()">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
      رجوع
    </button>
  </div>
  <div style="display:flex;flex-direction:column;align-items:center;padding:1rem 1.5rem 2.5rem;width:100%;">
    <div class="plan-header anim">
      <div class="user-avatar" id="planAvatar">م</div>
      <h2>اختر خطة المراقبة</h2>
      <p id="planWelcome">مرحباً، اختر الخطة المناسبة لطبيعة عملك</p>
    </div>
    <div class="plans-wrap">
      <!-- 24/7 — LOCKED / COMING SOON -->
      <div class="plan-card locked anim d1">
        <div class="plan-badge cs">قريباً</div>
        <div class="plan-icon" style="background:#f0f0f0;">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#aaa" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="plan-title" style="color:#999;">رقابة مستمرة 24/7</div>
        <div class="plan-sub">مراقبة لحظية لجميع مرضى الأمراض المزمنة مع تنبيهات فورية عند أي تغير حرج</div>
        <ul class="plan-feats" style="opacity:0.5;">
          <li>متابعة لحظية لقراءات القلب والسكر والضغط</li>
          <li>تنبيهات فورية عند القيم الحرجة</li>
          <li>لوحة تحكم شاملة للمرضى</li>
          <li>سجل تفصيلي لكل مريض</li>
          <li>تحليل ذكاء اصطناعي للتقارير الطبية</li>
        </ul>
        <div class="coming-soon-banner">🔒 هذه الخطة ستكون متاحة قريباً</div>
        <button class="select-plan-btn cs-btn" disabled>غير متاح حالياً</button>
      </div>
      <!-- PERIODIC — ACTIVE -->
      <div class="plan-card featured anim d2">
        <div class="plan-badge">متاح الآن</div>
        <div class="plan-icon">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#C8102E" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        </div>
        <div class="plan-title">رقابة دورية</div>
        <div class="plan-sub">قراءة وتحليل التقارير الطبية الدورية القادمة من المستوصف مع توضيح النتائج</div>
        <ul class="plan-feats">
          <li>رفع تقارير المستوصف (صورة أو PDF)</li>
          <li>قراءة التشخيص بالذكاء الاصطناعي</li>
          <li>توضيح النتائج بلغة مبسطة</li>
          <li>تصنيف القيم (طبيعي / مرتفع / منخفض)</li>
          <li>سجل التقارير السابقة</li>
        </ul>
        <button class="select-plan-btn" onclick="goToPage('periodicPage','planPage')">اختر هذه الخطة ←</button>
      </div>
    </div>
  </div>
</div>

<!-- ════════════════════════════════════
     PAGE 3 — PERIODIC
════════════════════════════════════ -->
<div class="page" id="periodicPage">
  <div class="topbar">
    <div class="topbar-left">
      <button class="back-btn" onclick="goBack()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>رجوع
      </button>
      <div class="topbar-logo">
        <svg width="26" height="26" viewBox="0 0 100 100" fill="none"><path d="M64 22C52 24.5 40 35 40 50C40 65 52 75.5 66 75.5C58 80 49 81 40 78.5C24 73.5 14 61 14 50C14 35 25 22.5 40 18.5C48 16 56.5 17.5 64 22Z" fill="#C8102E"/><circle cx="72" cy="34" r="6" fill="#C8102E" opacity="0.7"/></svg>
        <span>الرعاية الصحية</span>
      </div>
      <span class="plan-tag">رقابة دورية</span>
    </div>
    <div class="topbar-right">
      <div style="display:flex;align-items:center;gap:8px;">
        <div class="topbar-avatar" id="periAvatar">م</div>
        <span class="topbar-name" id="periName">المستخدم</span>
      </div>
      <button class="logout-btn" onclick="logout()">تسجيل الخروج</button>
    </div>
  </div>
  <div class="peri-body">
    <div class="dash-title anim">رفع وتحليل التقرير الطبي</div>
    <div class="dash-sub anim d1">ارفع تقرير المستوصف وسيقوم الذكاء الاصطناعي بقراءة النتائج وتوضيحها</div>
    <div class="upload-card anim d1">
      <h3>📋 رفع التقرير الطبي</h3>
      <p>ارفع صورة واضحة أو ملف PDF للتقرير الطبي من المستوصف أو المختبر</p>
      <div class="upload-zone" id="uz2">
        <input type="file" id="uf2" accept="image/*,.pdf" onchange="handleFile(event,'2')"/>
        <span class="upload-icon">📤</span>
        <div class="upload-title">اسحب التقرير هنا أو انقر للاختيار</div>
        <div class="upload-sub">يدعم صور JPG / PNG وملفات PDF</div>
      </div>
      <div class="file-preview" id="fp2">
        <span>📄</span>
        <span class="file-preview-name" id="fn2">—</span>
        <span class="file-preview-size" id="fs2">—</span>
        <button class="file-remove" onclick="removeFile('2')">✕</button>
      </div>
      <button class="analyze-btn" id="ab2" onclick="analyzeReport('2')" disabled>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        تحليل التقرير الآن
      </button>
    </div>
    <div class="ai-result" id="ar2"></div>
    <div class="hist-card anim d2" style="margin-top:1.4rem;">
      <h3>📁 سجل التقارير السابقة</h3>
      <table class="htable">
        <thead><tr><th>التاريخ</th><th>نوع التقرير</th><th>النتيجة</th><th>عرض</th></tr></thead>
        <tbody>
          <tr><td>١٥ مارس ٢٠٢٥</td><td>تحليل دم شامل</td><td><span class="status-pill badge-ok">طبيعي</span></td><td><button class="view-btn">عرض</button></td></tr>
          <tr><td>٢٨ يناير ٢٠٢٥</td><td>سكر + ضغط</td><td><span class="status-pill badge-warn">متابعة</span></td><td><button class="view-btn">عرض</button></td></tr>
          <tr><td>٥ ديسمبر ٢٠٢٤</td><td>أشعة قلب ECG</td><td><span class="status-pill badge-ok">طبيعي</span></td><td><button class="view-btn">عرض</button></td></tr>
          <tr><td>١٢ أكتوبر ٢٠٢٤</td><td>تحليل بول + دم</td><td><span class="status-pill badge-danger">قيم حرجة</span></td><td><button class="view-btn">عرض</button></td></tr>
        </tbody>
      </table>
    </div>
  </div>
</div>

